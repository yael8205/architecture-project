{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  },
  "Jwt": {
    "Key": "K8mN2pQ5vX9zA1bC3dE5fG7hJ9kL12",
    "Issuer": "LotteryApi",
    "Audience": "LotteryApiClients",
    "ExpiryMinutes": 120,
    "CookieName": "access_token"
  },
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "LotteryDb"
  },
  "Redis": {
    "Configuration": "localhost:6379",
    "InstanceName": "LotteryInstance_"
  },
  "CacheSettings": {
    "SlidingExpirationMinutes": 5,
    "Prefix": "Lottery:"
  },
  "AllowedHosts": "*"
}

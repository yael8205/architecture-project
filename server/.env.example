# Copy this file to .env and fill in real values.
# Do not commit .env to source control.

# Redis password used by both the Redis container and the API.
REDIS_PASSWORD=YourRedisPasswordHere

# API database connection string used by the ASP.NET Core app.
# The app reads this into ConnectionStrings:DefaultConnection.
API_CONNECTION_STRING=Server=sqlserver;Database=LotteryDB;User Id=sa;Password=YourDbPassword;TrustServerCertificate=True;

{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  },
  "JwtSettings": {
    "SecretKey": "2lRqcnFrNZwEDwUleHtcdsuxCLyrR04tFaw48ybqoVY",
    "Issuer": "LotteryApi",
    "Audience": "LotteryApiClients",
    "ExpiryMinutes": 120
  },
  "AllowedHosts": "*"
}
